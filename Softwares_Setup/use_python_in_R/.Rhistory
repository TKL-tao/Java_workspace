data <- read.csv("cgss2017.csv", header=TRUE, sep=",",na.strings = c(9999999,9999998,9999997,9999996,99,98,97,14,21,"#NULL!"))
data <- subset(data,select=c("a7a","a62","a18","a31","a2"))
names(data) <- c("edu","income","hukou","old","sex")
data <- na.omit(data)
data$sex[data$sex==2] <- 0
data$hukou[data$hukou==1] <- 0
data$hukou[data$hukou>=2] <- 1
income75 <- unname(quantile(data$income,0.75))
data$income[data$income<=income75] <- 0
data$income[data$income>=income75] <- 1
data$old <- 2016-data$old
data$old[data$old<=25] <- 0
data$old[data$old>25] <- 1
#print(paste("样本总数为：",nrow(data)))#样本总数11371
for(i in 1:ncol(data)){
data[,i] <- factor(data[,i])
}
data_hc_aic <- hc(data, score="aic")
graphviz.plot(data_hc_aic,main="基于AIC计分规则的爬山算法")
#create DAG
dag <- model2network("[old][sex][edu|old:hukou][income|sex:edu:hukou][hukou|old:edu]")
#create DAG
dag <- model2network("[old][sex][edu|old:hukou][income|sex:edu:hukou][hukou|old]")
bn_mle <- bn.fit(dag, data=data, method="mle")
bn_bayes <- bn.fit(dag, data=data, method="bayes", iss=20)
graphviz.plot(bn_mle)
graphviz.plot(bn_bayes)
bn_mle$edu
library(ggplot2)
library(bnlearn)
library(Rgraphviz)
library(knitr)
data <- read.csv("cgss2017.csv", header=TRUE, sep=",",na.strings = c(9999999,9999998,9999997,9999996,99,98,97,14,21,"#NULL!"))
data <- subset(data,select=c("a7a","a62","a18","a31","a2"))
names(data) <- c("edu","income","hukou","old","sex")
data <- na.omit(data)
data$sex[data$sex==2] <- 0
data$hukou[data$hukou==1] <- 0
data$hukou[data$hukou>=2] <- 1
income75 <- unname(quantile(data$income,0.75))
data$income[data$income<=income75] <- 0
data$income[data$income>=income75] <- 1
data$old <- 2016-data$old
data$old[data$old<=25] <- 0
data$old[data$old>25] <- 1
data$edu[data$edu<=10] <- 0
data$edu[data$edu>10] <- 1
#print(paste("样本总数为：",nrow(data)))#样本总数11371
for(i in 1:ncol(data)){
data[,i] <- factor(data[,i])
}
#create DAG
dag <- model2network("[old][sex][edu|old:hukou][income|sex:edu:hukou][hukou|old]")
bn_mle <- bn.fit(dag, data=data, method="mle")
bn_bayes <- bn.fit(dag, data=data, method="bayes", iss=20)
graphviz.plot(bn_mle)
graphviz.plot(bn_bayes)
bn_mle$edu
arc.strength(dag, data=data, criterion="x2")
summary(data)
data
